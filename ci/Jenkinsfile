pipeline {
    agent any

    parameters {
        booleanParam(
            name: 'IGNORE_UNFIXED',
            defaultValue: true,
            description: 'Ignore vulnerabilities with no fix available in Trivy scan'
        )
    }

    environment {
        IMAGE_NAME = "sample-nodejs"
        IMAGE_TAG  = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('SAST - Semgrep') {
            steps {
                sh "python3 ci/scripts/sast.py --workspace \${WORKSPACE}"
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    python3 ci/scripts/build.py \
                        --image-name ${IMAGE_NAME} \
                        --image-tag ${IMAGE_TAG}
                """
            }
        }

        stage('Trivy Scan') {
            steps {
                script {
                    def ignoreFlag = params.IGNORE_UNFIXED ? '--ignore-unfixed' : '--no-ignore-unfixed'
                    sh """
                        python3 ci/scripts/trivy_scan.py \
                            --image ${IMAGE_NAME}:${IMAGE_TAG} \
                            ${ignoreFlag}
                    """
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
            cleanWs()
        }
        failure {
            githubNotify context: 'Jenkins CI/PR',
                         description: 'PR checks failed — merge is blocked.',
                         status: 'FAILURE'
        }
        success {
            githubNotify context: 'Jenkins CI/PR',
                         description: 'All checks passed — PR is ready to merge.',
                         status: 'SUCCESS'
        }
    }
}
